# Terraform files to exclude from version control

# Local .terraform directories (contains provider binaries - very large!)
**/.terraform/*

# Terraform lock file (can be committed, but often excluded)
# .terraform.lock.hcl

# Terraform state files (contain sensitive infrastructure info)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Terraform variable files (may contain secrets)
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config file
.terraformrc
terraform.rc

# macOS
.DS_Store
